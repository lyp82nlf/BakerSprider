# Copy to .env and fill in real values.
BARKER_API_KEY=
WECOM_WEBHOOK_URL=

# Optional settings.
FETCH_INTERVAL_SECONDS=300
RATE_THRESHOLD_POINTS=1.0
ONLY_ACTIVE=true
